# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=false
SECRET_KEY=change-me-in-production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Frontend local dev: http://localhost:5173 (Vite)
# Modify CORS_ORIGINS to match your frontend URL in production
CORS_ORIGINS=http://localhost:5173,http://localhost:8085,https://your-site.netlify.app

# ── File Uploads ──────────────────────────────────────────────────────────────
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216

# ── Database (Neon PostgreSQL) ────────────────────────────────────────────────
# Set automatically by Netlify when Neon extension is connected
NETLIFY_DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/database
DATABASE_URL=postgresql://user:password@localhost/verifixia

# ── Firebase Admin SDK (Backend) ──────────────────────────────────────────────
# Firebase requires either a credentials file OR credentials JSON string
# 
# OPTION 1: Path to Firebase service account key (JSON file)
#   - Download from Firebase Console → Project Settings → Service Accounts
#   - Click "Generate new private key"
#   - Save to Backend/firebase-key.json (add to .gitignore!)
FIREBASE_CREDENTIALS_PATH=firebase-key.json

# Bypass user authentication entirely (returns a fake user for every request).
# Useful when testing without a Firebase setup. Set to 'true' to enable.
BYPASS_LOGIN=false

# OPTION 2: Firebase credentials as JSON string (for CI/CD environments)
#   - Paste the entire Firebase service account JSON here
#   - Keep as single line for .env file
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"verifixia-260f2",...}

# ── Firebase Client SDK (Frontend) ────────────────────────────────────────────
# These values are for the browser SDK (Frontend/.env)
# Designed to be public (all VITE_ variables are exposed to browser)
# Get these from Firebase Console → Project Settings → Your Apps → Web app config
#
VITE_FIREBASE_API_KEY=YOUR_API_KEY_HERE
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID
VITE_FIREBASE_MEASUREMENT_ID=G_XXXXXXXXXX
VITE_FIREBASE_DATABASE_URL=https://YOUR_PROJECT-default-rtdb.REGION.firebasedatabase.app

# ── Model URLs (Optional) ─────────────────────────────────────────────────────
# For production: Set these to CDN URLs for automatic model downloads
# MODEL_URL=https://cdn.example.com/xception_deepfake.pth
# SKLEARN_URL=https://cdn.example.com/deepfake_sklearn.pkl