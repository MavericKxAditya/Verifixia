# ── Backend API ───────────────────────────────────────────────────────────────
# The Flask API runs on http://localhost:3001 by default
# For production, set to your deployed backend URL
VITE_API_BASE_URL=http://localhost:3001

# Use mock API for testing when backend is unavailable (set to 'true' to enable)
VITE_USE_MOCK_API=false

# Bypass authentication entirely (ignore Firebase) when set to 'true'.
# Handy for locally skipping the login page during development.
VITE_BYPASS_LOGIN=false

# ── Firebase Client SDK ───────────────────────────────────────────────────────
# Copy these values from Firebase Console → Project Settings → Your Apps → Web app
# 
# IMPORTANT: These values are PUBLIC, do not use production secrets here
# - Only use web API keys (not the admin SDK credentials)
# - All VITE_ prefixed variables are exposed to the browser
# 
# Get values from:
#   1. Go to https://console.firebase.google.com
#   2. Select your project
#   3. Click Settings (gear icon) → Project Settings
#   4. Go to "Your Apps" section
#   5. Copy the config values below

